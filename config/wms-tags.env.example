# Copy to wms-tags.env and place next to the JAR (or set WMS_CONFIG_FILE path).
# Either key is accepted (WMS_ENV preferred, ACTIVE_ENV supported):
WMS_ENV=DEV
#ACTIVE_ENV=DEV
ACTIVE_SITE=TBG3002
ORACLE_USERNAME=CHANGE_ME
ORACLE_PASSWORD=CHANGE_ME
ORACLE_PORT=1521
ORACLE_SERVICE=CHANGE_ME
# Optional DSN override:
#ORACLE_DSN=(DESCRIPTION=(ADDRESS_LIST=(ADDRESS=(PROTOCOL=TCP)(HOST=10.19.96.121)(PORT=1521)))(CONNECT_DATA=(SERVICE_NAME=jcnwmsdbd01)))
# Optional Oracle Net alias fallback (ODBC/TNS alias configured on user PCs):
#ORACLE_ODBC_DSN=TBG3002
SITE_TBG3002_NAME=Example Site
SITE_TBG3002_SHIP_FROM_NAME=Example Company
SITE_TBG3002_SHIP_FROM_ADDRESS=123 Example St
SITE_TBG3002_SHIP_FROM_CITY_STATE_ZIP=Example City, ST 00000
SITE_TBG3002_PROD_HOST=example-host
PRINTER_INVENTORY_FILE=config/TBG3002/printers.yaml
PRINTER_ROUTING_FILE=config/TBG3002/printer-routing.yaml
# Optional rail PDF print target override (printers.yaml ID):
#RAIL_DEFAULT_PRINTER_ID=RAIL_OFFICE
# Rail label PDF calibration (inches):
RAIL_LABEL_CENTER_GAP_IN=0.125
RAIL_LABEL_OFFSET_X_IN=0.02
RAIL_LABEL_OFFSET_Y_IN=0.02
