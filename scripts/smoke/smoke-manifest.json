{
  "version": 1,
  "description": "Shared release smoke scenarios for repo and packaged execution targets.",
  "scenarios": [
    {
      "name": "config",
      "tier": 1,
      "modes": ["repo", "packaged"],
      "command": "config",
      "expectedExitCode": 0,
      "expectedArtifacts": []
    },
    {
      "name": "db-test",
      "tier": 1,
      "modes": ["repo", "packaged"],
      "command": "db-test",
      "expectedExitCode": 0,
      "expectedArtifacts": []
    },
    {
      "name": "shipment-print-to-file",
      "tier": 1,
      "modes": ["repo", "packaged"],
      "command": "run --shipment-id {shipmentId} --print-to-file --output-dir {outputDir}",
      "expectedExitCode": 0,
      "expectedArtifacts": ["*.zpl"]
    },
    {
      "name": "carrier-move-print-to-file",
      "tier": 1,
      "modes": ["repo", "packaged"],
      "command": "run --carrier-move-id {carrierMoveId} --print-to-file --output-dir {outputDir}",
      "expectedExitCode": 0,
      "expectedArtifacts": ["*.zpl"]
    },
    {
      "name": "rail-template",
      "tier": 1,
      "modes": ["repo", "packaged"],
      "command": "rail-print --template --output-dir {outputDir}",
      "expectedExitCode": 0,
      "expectedArtifacts": ["*.pdf"]
    },
    {
      "name": "rail-render",
      "tier": 1,
      "modes": ["repo", "packaged"],
      "command": "rail-print --train {trainId} --yes --output-dir {outputDir}",
      "expectedExitCode": 0,
      "expectedArtifacts": ["*.pdf"]
    },
    {
      "name": "packaged-config-assets",
      "tier": 1,
      "modes": ["packaged"],
      "command": "config",
      "expectedExitCode": 0,
      "expectedArtifacts": [
        "config\\walmart-sku-matrix.csv",
        "config\\walm_loc_num_matrix.csv",
        "config\\TBG3002\\printers.yaml",
        "config\\TBG3002\\printer-routing.yaml"
      ]
    },
    {
      "name": "tropicana-config-precedence",
      "tier": 2,
      "modes": ["packaged"],
      "command": "config",
      "expectedExitCode": 0,
      "expectedArtifacts": []
    },
    {
      "name": "rail-office-printer-reachability",
      "tier": 2,
      "modes": ["repo", "packaged"],
      "command": "printer-reachability",
      "expectedExitCode": 0,
      "expectedArtifacts": []
    }
  ]
}
